# =============================================================================
# AESTHETIX V-Track — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to version control!
# =============================================================================

# Firebase Configuration
# Get these from: https://console.firebase.google.com → Project Settings → General
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:your_app_id_here

# Single-User Authentication
# The email and password for the single authorized user
SINGLE_USER_EMAIL=your-email@example.com
SINGLE_USER_PASSWORD=your_secure_password_here

# Google OAuth Client ID (for Google Fit integration)
# Get this from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Docker / Deployment
# Container name for Docker Compose
CONTAINER_NAME=vtrack-app
# Port mapping (host port → container port 80)
VTRACK_PORT=8080
